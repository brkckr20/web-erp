  hataAdi           String   @map("hata_adi") @db.VarChar(200)
  ozelKod           String?  @map("ozel_kod") @db.VarChar(100)
  kullanimda        Boolean  @default(true)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("hata_tanim")
}

model KaliteKontrolHata {
  id                Int      @id @default(autoincrement())
  kalemId           Int      @map("kalem_id")
  kalem             KaliteKontrolKalem @relation("KKHataKalem", fields: [kalemId], references: [id])

  hataKodu          String   @map("hata_kodu") @db.VarChar(50)
  hataAdi           String   @map("hata_adi") @db.VarChar(200)
  miktar            Int?     @default(1)
  aciklama          String?  @db.VarChar(1000)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("kalite_kontrol_hata")
}

model Renk {
  id                Int      @id @default(autoincrement())
  kod               String   @unique @db.VarChar(50)
  ad                String   @db.VarChar(200)
  tip               Int      @default(1)
  aciklama          String?  @db.VarChar(1000)
  renk              String?  @db.VarChar(20)
  cariKodu          String?  @map("cari_kodu") @db.VarChar(50)
  talepTarihi       DateTime? @map("talep_tarihi")
  okeyTarihi        DateTime? @map("okey_tarihi")
  fiyat             Decimal? @db.Decimal(18, 6)
  dovizCinsi        String?  @map("doviz_cinsi") @db.VarChar(10)
  kullanimda        Boolean  @default(true)

  tarih             DateTime? @db.Date
  ozelKod           String?  @map("ozel_kod") @db.VarChar(50)
  pantoneNo         String?  @map("pantone_no") @db.VarChar(50)
  renkTuru          String?  @map("renk_turu") @db.VarChar(50)
  parentRenkId      Int?     @map("parent_renk_id")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  cariHesap         CariHesap? @relation("RenkCariHesap", fields: [cariKodu], references: [kod])
  parentRenk        Renk?      @relation("RenkParent", fields: [parentRenkId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childRenkler      Renk[]     @relation("RenkParent")

  @@map("renk")
}

model Beden {
  id                Int      @id @default(autoincrement())
  kod               String   @unique @db.VarChar(20)
  sira              Int      @default(0)
  kullanimda        Boolean  @default(true)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  olculer           ReceteOlcu[] @relation("OlcuBeden")
  malzemeBedenler   MalzemeBeden[] @relation("BedenMalzeme")

  @@map("beden")
}

model MalzemeBeden {
  id                Int      @id @default(autoincrement())
  malzemeId         Int      @map("malzeme_id")
  bedenId           Int      @map("beden_id")

  createdAt         DateTime @default(now()) @map("created_at")

  malzeme           Malzeme @relation("MalzemeBedenRef", fields: [malzemeId], references: [id], onDelete: Cascade)
  beden             Beden @relation("BedenMalzeme", fields: [bedenId], references: [id], onDelete: Cascade)

  @@unique([malzemeId, bedenId])
  @@map("malzeme_beden")
}

model ModelRecete {
  id                Int      @id @default(autoincrement())
  malzemeId         Int      @map("malzeme_id")
  aciklama          String?  @db.VarChar(500)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  malzeme           Malzeme? @relation("ReceteMalzeme", fields: [malzemeId], references: [id], onDelete: Cascade)
  kalemler          ReceteKalem[] @relation("KalemRecete")

  @@map("model_recete")
}

model ReceteKalem {
  id                Int      @id @default(autoincrement())
  receteId          Int      @map("recete_id")
  sira              Int      @default(0)
  malzemeId         Int?     @map("malzeme_id")
  birimFiyat        Decimal? @map("birim_fiyat") @db.Decimal(18, 6)
  dovizCinsi        String?  @map("doviz_cinsi") @db.VarChar(10)
  aciklama          String?  @db.VarChar(500)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  recete            ModelRecete? @relation("KalemRecete", fields: [receteId], references: [id], onDelete: Cascade)
  malzeme           Malzeme? @relation("KalemMalzemeRef", fields: [malzemeId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  olculer           ReceteOlcu[] @relation("OlcuKalem")

  @@map("recete_kalem")
}

model ReceteOlcu {
  id                Int      @id @default(autoincrement())
  kalemId           Int      @map("kalem_id")
  bedenId           Int      @map("beden_id")
  metraj            Decimal? @db.Decimal(18, 6)
  en                Decimal? @db.Decimal(18, 6)
  boy               Decimal? @db.Decimal(18, 6)
  miktar            Decimal? @db.Decimal(18, 6)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  kalem             ReceteKalem? @relation("OlcuKalem", fields: [kalemId], references: [id], onDelete: Cascade)
  beden             Beden? @relation("OlcuBeden", fields: [bedenId], references: [id])

  @@unique([kalemId, bedenId])
  @@map("recete_olcu")
}
